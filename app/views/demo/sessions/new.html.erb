<% content_for :title, "Try compliventory — demo" %>

<div class="w-full max-w-lg mx-auto mt-12">
  <%= render "shared/flash" %>

  <div class="flex flex-col items-center text-center mb-8">
    <%= brand_mark(css_class: "w-11 h-11 mb-4") %>
    <h1 class="page-title">Try compliventory</h1>
    <p class="page-subtitle mt-1">The company's vendors and systems, accounted for.</p>
  </div>

  <div class="card p-6">
    <p class="text-sm text-gray-600 mb-1">
      Pick a persona to explore as. Everyone shares one sandbox, so you'll see
      each other's changes — that's the point. Try submitting a vendor as an
      employee, then approving it as compliance.
    </p>
    <p class="field-hint mb-5">Demo data resets every night. Emails aren't actually delivered.</p>

    <div class="space-y-2">
      <% @users.each do |user| %>
        <%= button_to demo_sign_in_path, method: :post, params: { email: user.email },
                      class: "w-full flex items-center justify-between gap-3 px-4 py-3 card card-hover text-sm text-left" do %>
          <span>
            <span class="font-medium text-gray-900"><%= user.name %></span>
            <span class="block text-xs text-gray-500 mt-0.5"><%= demo_persona_hint(user.role) %></span>
          </span>
          <span class="pill bg-gray-100 text-gray-600 shrink-0"><%= user.role %></span>
        <% end %>
      <% end %>
    </div>
  </div>

  <p class="text-center mt-6">
    <%= link_to "Documentation ↗", "https://spryffee.github.io/compliventory", class: "text-sm text-pine-700 font-medium hover:underline", target: "_blank", rel: "noopener" %>
  </p>
</div>
