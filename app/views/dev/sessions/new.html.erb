<% content_for :title, "Developer sign-in — Compliventory" %>

<div class="w-full max-w-sm mx-auto mt-12">
  <%= render "shared/flash" %>
  <div class="mb-4 p-3 rounded-lg bg-amber-50 border border-amber-200 text-amber-800 text-xs">
    Development only — one-click impersonation of a seeded user.
  </div>

  <h1 class="page-title mb-6">Developer sign-in</h1>

  <% if @users.empty? %>
    <p class="text-sm text-gray-600">No active users. Run <code>bin/rails db:seed</code>.</p>
  <% else %>
    <div class="space-y-2">
      <% @users.each do |user| %>
        <%= button_to dev_sign_in_path, method: :post, params: { email: user.email },
                      class: "w-full flex items-center justify-between px-4 py-3 card card-hover text-sm" do %>
          <span class="font-medium"><%= user.name %></span>
          <span class="text-gray-500"><%= user.email %><%= " · #{user.role}" unless user.member? %></span>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
