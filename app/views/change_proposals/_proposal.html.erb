<%# locals: proposal, show_asset %>
<div class="card p-5">
  <div class="flex items-start justify-between gap-3">
    <div class="min-w-0">
      <% if show_asset %>
        <div class="text-sm font-medium">
          <%= link_to proposal.asset.name, proposal.asset, class: "text-gray-900 hover:text-pine-700" %>
          <span class="pill bg-gray-100 text-gray-600 ml-1"><%= proposal.asset.model_name.human %></span>
          <% if proposal.lane == "compliance" %>
            <span class="pill bg-pine-50 text-pine-700 ml-1">⚖ compliance</span>
          <% end %>
        </div>
      <% end %>
      <div class="text-xs text-gray-500 mt-0.5">
        proposed by <%= proposal.proposer.name %> · <%= audit_timestamp(proposal.created_at) %>
      </div>
    </div>
  </div>

  <div class="mt-3 space-y-1">
    <% proposal.attribute_changes.each do |field, (base, proposed)| %>
      <div class="text-sm text-gray-700">
        <span class="font-medium"><%= field.humanize %></span>:
        <span class="text-gray-500"><%= change_value(field, base) %></span>
        <% if proposal.stale?(field) %>
          <span class="text-amber-600" title="Changed since this was proposed">→ now <%= change_value(field, proposal.current_value(field)) %></span>
        <% end %>
        → <span class="font-medium text-gray-900"><%= change_value(field, proposed) %></span>
      </div>
    <% end %>
  </div>

  <% if proposal.justification.present? %>
    <div class="mt-2 text-sm text-gray-600 italic">"<%= proposal.justification %>"</div>
  <% end %>

  <% if ProposalPolicy.new(current_user, proposal).may_decide? %>
    <%= form_with url: approve_proposal_path(proposal), class: "mt-4 flex flex-wrap items-center gap-2" do %>
      <%= text_field_tag :comment, nil, placeholder: "Optional comment", class: "input flex-1 min-w-40 py-1.5 text-sm" %>
      <%= submit_tag "Approve", class: "btn btn-primary btn-sm" %>
      <%= submit_tag "Reject", formaction: reject_proposal_path(proposal), class: "btn btn-danger btn-sm" %>
    <% end %>
  <% end %>
</div>
