<% content_for :title, "Compliventory" %>

<%= render "shared/topbar" %>

<div class="max-w-5xl mx-auto">
  <h1 class="page-title mb-1">Welcome, <%= current_user.name.split.first %></h1>
  <p class="page-subtitle mb-8">The company's vendors and systems, accounted for.</p>

  <% if @inbox_proposals.any? || (@pending_submissions.to_i + @compliance_proposals.to_i).positive? %>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-8">
      <% if @inbox_proposals.any? %>
        <%= link_to inbox_path, class: "card card-hover p-5 block" do %>
          <div class="flex items-center gap-2 text-sm font-medium text-gray-900 mb-2">
            <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span>
            <%= pluralize(@inbox_proposals.size, "proposed change") %> waiting for your review
          </div>
          <div class="space-y-1">
            <% @inbox_proposals.first(3).each do |proposal| %>
              <div class="text-sm text-gray-600 truncate">
                <span class="text-gray-900"><%= proposal.asset.name %></span>
                — <%= proposal.attribute_changes.keys.map(&:humanize).join(", ") %>
                · by <%= proposal.proposer.name %>
              </div>
            <% end %>
            <% if @inbox_proposals.size > 3 %>
              <div class="text-xs text-gray-400">and <%= @inbox_proposals.size - 3 %> more…</div>
            <% end %>
          </div>
        <% end %>
      <% end %>

      <% if (@pending_submissions.to_i + @compliance_proposals.to_i).positive? %>
        <%= link_to compliance_path, class: "card card-hover p-5 block" do %>
          <div class="flex items-center gap-2 text-sm font-medium text-gray-900 mb-2">
            <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span>
            Compliance queue
          </div>
          <div class="text-sm text-gray-600">
            <%= pluralize(@pending_submissions, "pending submission") %> ·
            <%= pluralize(@compliance_proposals, "gated-field proposal") %>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
    <% [ [ "Your vendors", @my_vendors, vendors_path, "All vendors" ],
         [ "Your systems", @my_systems, systems_path, "All systems" ] ].each do |title, assets, index_path, all_label| %>
      <div class="card p-5">
        <div class="flex items-center justify-between mb-3">
          <div class="text-sm font-medium text-gray-900"><%= title %></div>
          <%= link_to all_label + " →", index_path, class: "text-sm text-pine-700 font-medium hover:underline" %>
        </div>
        <% if assets.empty? %>
          <div class="text-sm text-gray-500">Nothing you own or co-manage yet.</div>
        <% else %>
          <div class="space-y-1.5">
            <% assets.each do |asset| %>
              <div class="flex items-center justify-between gap-2 text-sm">
                <span class="truncate">
                  <%= link_to asset.name, asset, class: "text-gray-900 hover:text-pine-700" %>
                  <% if asset.owner_id != current_user.id %>
                    <span class="pill bg-gray-100 text-gray-500 ml-1">delegate</span>
                  <% end %>
                </span>
                <%= status_pill(asset.status) %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <% if @recent_events.any? %>
    <h2 class="text-sm font-medium text-gray-900 mt-8 mb-3">Recent activity on your assets</h2>
    <div class="card divide-y divide-gray-100">
      <% @recent_events.each do |event| %>
        <div class="px-5 py-2.5 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm">
          <span class="text-gray-500 text-xs"><%= audit_timestamp(event.occurred_at) %></span>
          <span class="pill bg-gray-100 text-gray-700"><%= event.event_type %></span>
          <span class="text-gray-600"><%= event.actor_display || "system" %></span>
          <span class="text-gray-600"><%= safe_join(event.targets.map { |t| audit_target_tag(t) }, ", ") %></span>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
