<% content_for :title, "Compliance inbox — Compliventory" %>

<%= render "shared/topbar" %>

<div class="max-w-3xl mx-auto">
  <h1 class="page-title mb-1">Compliance inbox</h1>
  <p class="page-subtitle mb-6">New submissions awaiting approval and ⚖ field changes awaiting review.</p>

  <h2 class="section-label mb-2">New submissions</h2>
  <% pending_assets = @pending_vendors + @pending_systems %>
  <% if pending_assets.empty? %>
    <div class="card p-5 text-sm text-gray-500 mb-8">No pending submissions.</div>
  <% else %>
    <div class="space-y-4 mb-8">
      <% pending_assets.each do |asset| %>
        <div class="card p-5">
          <div class="text-sm font-medium">
            <%= link_to asset.name, asset, class: "text-gray-900 hover:text-pine-700" %>
            <span class="pill bg-gray-100 text-gray-600 ml-1"><%= asset.model_name.human %></span>
          </div>
          <div class="text-xs text-gray-500 mt-0.5">
            owner <%= asset.owner.name %> · submitted <%= audit_timestamp(asset.created_at) %>
          </div>
          <% if asset.description.present? %>
            <div class="mt-2 text-sm text-gray-600"><%= asset.description %></div>
          <% end %>
          <%= form_with url: url_for([ :approve, asset ]), class: "mt-4 flex flex-wrap items-center gap-2" do %>
            <%= text_field_tag :comment, nil, placeholder: "Optional comment", class: "input flex-1 min-w-40 py-1.5 text-sm" %>
            <%= submit_tag "Approve", class: "btn btn-primary btn-sm" %>
            <%= submit_tag "Reject", formaction: url_for([ :reject, asset ]), class: "btn btn-danger btn-sm",
                  data: { turbo_confirm: "Reject and remove #{asset.name}? The snapshot stays in the audit log." } %>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>

  <h2 class="section-label mb-2">Field changes ⚖</h2>
  <% if @proposals.empty? %>
    <div class="card p-5 text-sm text-gray-500 mb-8">No pending field changes.</div>
  <% else %>
    <div class="space-y-4 mb-8">
      <% @proposals.each do |proposal| %>
        <%= render "change_proposals/proposal", proposal: proposal, show_asset: true %>
      <% end %>
    </div>
  <% end %>

  <h2 class="section-label mb-2">Risk assessments</h2>
  <% if @in_progress_assessments.empty? && @overdue_vendors.empty? && @never_assessed_vendors.empty? %>
    <div class="card p-5 text-sm text-gray-500">Every active vendor is up to date. Nothing to assess.</div>
  <% else %>
    <div class="card divide-y divide-gray-100">
      <% @in_progress_assessments.each do |assessment| %>
        <%= link_to vendor_assessment_path(assessment.asset, assessment),
              class: "flex items-center justify-between gap-2 px-5 py-3 text-sm hover:bg-gray-50 transition-colors" do %>
          <span>
            <span class="font-medium text-gray-900"><%= assessment.asset.name %></span>
            <span class="text-gray-500">· started by <%= assessment.assessor.name %></span>
          </span>
          <span class="pill bg-amber-50 text-amber-700">In progress</span>
        <% end %>
      <% end %>

      <% @overdue_vendors.each do |vendor| %>
        <%= link_to vendor_path(vendor),
              class: "flex items-center justify-between gap-2 px-5 py-3 text-sm hover:bg-gray-50 transition-colors" do %>
          <span>
            <span class="font-medium text-gray-900"><%= vendor.name %></span>
            <span class="text-gray-500">· review due <%= review_due_tag(vendor.next_review_on) %></span>
          </span>
          <%= risk_pill(vendor.risk_tier) %>
        <% end %>
      <% end %>

      <% @never_assessed_vendors.each do |vendor| %>
        <%= link_to vendor_path(vendor),
              class: "flex items-center justify-between gap-2 px-5 py-3 text-sm hover:bg-gray-50 transition-colors" do %>
          <span class="font-medium text-gray-900"><%= vendor.name %></span>
          <span class="pill bg-gray-100 text-gray-500">Never assessed</span>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
