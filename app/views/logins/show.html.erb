<% content_for :title, "Sign in — Compliventory" %>

<div class="w-full max-w-sm mx-auto mt-12">
  <div class="flex flex-col items-center text-center mb-8">
    <%= brand_mark(css_class: "w-11 h-11 mb-4") %>
    <h1 class="page-title">Sign in to Compliventory</h1>
    <p class="page-subtitle mt-1">Vendors and systems, accounted for.</p>
  </div>

  <div class="card p-6">
    <% if @oidc_configured %>
      <%= button_to "Continue with SSO", "/auth/oidc",
                    method: :post,
                    data: { turbo: false },
                    class: "btn btn-primary w-full" %>
    <% else %>
      <p class="text-sm text-gray-600">
        Single sign-on is not configured. Set
        <code class="font-mono text-xs bg-gray-100 px-1.5 py-0.5 rounded">OIDC_ISSUER</code>,
        <code class="font-mono text-xs bg-gray-100 px-1.5 py-0.5 rounded">OIDC_CLIENT_ID</code> and
        <code class="font-mono text-xs bg-gray-100 px-1.5 py-0.5 rounded">OIDC_CLIENT_SECRET</code>
        to enable it.
      </p>
    <% end %>

    <% if Rails.env.development? %>
      <div class="mt-5 pt-5 border-t border-gray-200 text-center">
        <%= link_to "Developer sign-in →", dev_sign_in_path, class: "text-sm text-pine-700 font-medium hover:underline" %>
      </div>
    <% end %>
  </div>
</div>
