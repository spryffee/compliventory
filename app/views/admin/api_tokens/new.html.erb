<% content_for :title, "New API token — Compliventory" %>

<div class="max-w-5xl mx-auto">
  <%= render "admin/nav" %>

  <h1 class="page-title mb-6">Create API token</h1>

  <%= form_with model: [ :admin, @api_token ], local: true, class: "space-y-5 max-w-lg" do |f| %>
    <% if @api_token.errors.any? %>
      <div class="p-3 rounded-lg bg-red-50 border border-red-200 text-red-800 text-sm space-y-1">
        <% @api_token.errors.full_messages.each do |msg| %>
          <div>• <%= msg %></div>
        <% end %>
      </div>
    <% end %>

    <div>
      <%= f.label :name, class: "field-label" %>
      <%= f.text_field :name, required: true, class: input_class, placeholder: "HRIS sync, governauthzer bridge, ..." %>
      <p class="field-hint">Human-readable label identifying the consumer. Not visible to the token holder.</p>
    </div>

    <div>
      <%= f.label :expires_at, "Expires at", class: "field-label" %>
      <%= f.datetime_local_field :expires_at, class: input_class %>
      <p class="field-hint">Leave blank for a token that never expires.</p>
    </div>

    <div class="rounded border border-gray-200 bg-gray-50 p-3 text-xs text-gray-600">
      All tokens carry the <code class="font-mono">users:write</code> scope (the sync API is the
      only API surface). The plain token value will be displayed <strong>once</strong> after
      creation — if you miss it, revoke and generate a new one.
    </div>

    <div class="flex items-center gap-3 pt-2">
      <%= f.submit "Generate token", class: "btn btn-primary" %>
      <%= link_to "Cancel", admin_api_tokens_path, class: "btn-quiet" %>
    </div>
  <% end %>
</div>
