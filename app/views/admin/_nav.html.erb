<% nav_link = ->(label, path, active) {
     link_to label, path,
       class: "shrink-0 px-3 py-1.5 rounded-md text-sm transition-colors #{active ? 'text-gray-900 font-medium underline underline-offset-4 decoration-2 decoration-pine-500' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-100'}"
   } %>
<% menu_link = ->(label, path, active) {
     link_to label, path,
       class: "block px-2 py-2 rounded-md text-sm #{active ? 'text-gray-900 font-medium bg-pine-50' : 'text-gray-700 hover:bg-gray-100'}"
   } %>
<% sections = [
     [ "Users",      admin_users_path,      controller_name == "users" ],
     [ "API tokens", admin_api_tokens_path, controller_name == "api_tokens" ]
   ] %>

<div class="fixed top-3 inset-x-0 z-40" data-controller="menu">
  <div class="container mx-auto px-5">
    <div class="max-w-5xl mx-auto relative">
      <header class="flex items-center justify-between gap-3
                     h-12 pl-2 pr-2 rounded-lg bg-white/90 backdrop-blur shadow-md">
        <div class="flex items-center gap-1 min-w-0">
          <%= link_to admin_root_path, class: "shrink-0 flex items-center justify-center w-7 h-7 mr-0.5" do %>
            <%= brand_mark %>
          <% end %>
          <span class="text-xs font-semibold uppercase tracking-wider text-gray-400 mr-2">Admin</span>
          <%# Desktop: inline nav %>
          <nav class="hidden sm:flex items-center gap-1">
            <% sections.each do |label, path, active| %>
              <%= nav_link.(label, path, active) %>
            <% end %>
          </nav>
        </div>

        <div class="flex items-center gap-2 shrink-0">
          <span class="hidden sm:inline text-sm text-gray-400"><%= current_user.name %></span>
          <%= link_to "App ↗", root_path, class: "hidden sm:inline-block shrink-0 px-3 py-1.5 rounded-md text-sm text-pine-700 font-medium hover:bg-pine-50" %>
          <%# Mobile: hamburger %>
          <button type="button" class="sm:hidden shrink-0 flex items-center justify-center w-9 h-9 rounded-md text-gray-600 hover:text-gray-900 hover:bg-gray-100"
                  data-action="menu#toggle" data-menu-target="button"
                  aria-label="Menu" aria-expanded="false" aria-haspopup="true">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
              <line x1="4" y1="7" x2="20" y2="7"></line>
              <line x1="4" y1="12" x2="20" y2="12"></line>
              <line x1="4" y1="17" x2="20" y2="17"></line>
            </svg>
          </button>
        </div>
      </header>

      <%# Mobile: dropdown panel %>
      <div data-menu-target="panel"
           class="sm:hidden hidden absolute top-full right-0 mt-2 w-52 origin-top-right
                  rounded-lg bg-white shadow-lg border border-gray-200 p-1.5">
        <nav class="flex flex-col">
          <% sections.each do |label, path, active| %>
            <%= menu_link.(label, path, active) %>
          <% end %>
        </nav>
        <div class="mt-1.5 pt-1.5 border-t border-gray-100">
          <%= link_to "App ↗", root_path, class: "block px-2 py-2 rounded-md text-sm text-pine-700 font-medium hover:bg-pine-50" %>
        </div>
      </div>
    </div>
  </div>
</div>
<div class="h-12" aria-hidden="true"></div>
