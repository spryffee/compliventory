<% content_for :title, "Users — Compliventory" %>

<div class="max-w-5xl mx-auto">
  <%= render "admin/nav" %>
  <%= render "shared/flash" %>

  <div class="flex items-center justify-between mb-2">
    <h1 class="page-title">Users</h1>
    <div class="flex items-center gap-1 text-sm">
      <%= link_to "All", admin_users_path,
            class: @role.blank? ? "px-2.5 py-1 rounded font-medium bg-gray-100 text-gray-900" : "px-2.5 py-1 rounded text-gray-500 hover:text-gray-900" %>
      <% User::ROLES.each do |role| %>
        <%= link_to role.humanize, admin_users_path(role: role),
              class: @role == role ? "px-2.5 py-1 rounded font-medium bg-gray-100 text-gray-900" : "px-2.5 py-1 rounded text-gray-500 hover:text-gray-900" %>
      <% end %>
    </div>
  </div>
  <p class="page-subtitle mb-6">
    Users arrive via the sync API — there is no manual create or delete here.
    Deactivated users keep their history but can't sign in.
  </p>

  <div class="panel">
    <table class="data-table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Email</th>
          <th>Status</th>
          <th>Role</th>
        </tr>
      </thead>
      <tbody>
        <% @users.each do |user| %>
          <tr class="row-hover">
            <td class="font-medium text-gray-900"><%= user.name %></td>
            <td class="text-gray-600"><%= user.email %></td>
            <td>
              <% if user.active? %>
                <span class="pill bg-gray-100 text-gray-700"><span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>Active</span>
              <% else %>
                <span class="pill bg-gray-100 text-gray-700"><span class="w-1.5 h-1.5 rounded-full bg-red-500"></span>Inactive</span>
              <% end %>
            </td>
            <td>
              <%= form_with url: admin_user_path(user), method: :patch, data: { controller: "autosubmit" } do |f| %>
                <%= f.select "user[role]", User::ROLES.map { |r| [ r.humanize, r ] }, { selected: user.role },
                      class: "input w-36 py-1 text-sm",
                      data: { action: "change->autosubmit#submit" },
                      disabled: user == current_user %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
