<%# locals: vendor, inherent_risk, assessments, in_progress_assessment, assessment_policy %>
<div>
  <div class="flex items-center justify-between mb-2">
    <h2 class="section-label">Risk</h2>
    <% if in_progress_assessment %>
      <%= link_to "Continue assessment", vendor_assessment_path(vendor, in_progress_assessment), class: "btn btn-primary btn-sm" %>
    <% elsif assessment_policy.may_assess? && !vendor.pending_approval? %>
      <%= button_to "Start assessment", vendor_assessments_path(vendor), class: "btn btn-primary btn-sm" %>
    <% end %>
  </div>

  <div class="card overflow-hidden">
    <div class="grid grid-cols-2 divide-x divide-gray-100">
      <div class="p-4">
        <div class="section-label text-gray-400 mb-2">Inherent</div>
        <%= risk_indicator(inherent_risk[:level]) %>
        <div class="text-xs text-gray-400 mt-1.5">computed from inventory</div>
      </div>
      <div class="p-4">
        <div class="section-label text-gray-400 mb-2">Residual</div>
        <%= risk_indicator(vendor.risk_tier) %>
        <div class="text-xs text-gray-400 mt-1.5">
          <%= vendor.last_assessed_on ? "assessed #{vendor.last_assessed_on.strftime('%b %-d, %Y')}" : "not yet assessed" %>
        </div>
      </div>
    </div>

    <% if vendor.next_review_on %>
      <div class="px-4 py-2.5 border-t border-gray-100 flex items-center justify-between text-xs">
        <span class="text-gray-500">Next review</span>
        <%= review_due_tag(vendor.next_review_on) %>
      </div>
    <% end %>

    <% if inherent_risk[:factors].any? %>
      <div class="px-4 py-3 border-t border-gray-100 bg-gray-50">
        <div class="text-xs text-gray-500 mb-2">Why inherent risk is <%= inherent_risk[:level].humanize.downcase %></div>
        <ul class="space-y-1.5">
          <% inherent_risk[:factors].each do |factor| %>
            <li class="flex items-center gap-2"><%= factor_line(factor) %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
  </div>

  <% if assessments.any? %>
    <div class="mt-4">
      <h3 class="section-label text-gray-400 mb-1.5">History</h3>
      <div class="card divide-y divide-gray-100 overflow-hidden">
        <% assessments.each do |assessment| %>
          <%= link_to vendor_assessment_path(vendor, assessment),
                class: "flex items-center justify-between gap-2 px-4 py-2.5 text-sm hover:bg-gray-50 transition-colors" do %>
            <span class="text-gray-700">
              <% if assessment.completed? %>
                <%= assessment.completed_at.strftime("%b %-d, %Y") %>
              <% else %>
                Started <%= assessment.created_at.strftime("%b %-d, %Y") %>
              <% end %>
            </span>
            <span class="flex items-center gap-2">
              <% if assessment.completed? %>
                <span class="text-gray-500 text-xs"><%= decision_label(assessment.decision) %></span>
                <%= risk_pill(assessment.residual_risk) %>
              <% else %>
                <span class="pill bg-amber-50 text-amber-700">In progress</span>
              <% end %>
            </span>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
