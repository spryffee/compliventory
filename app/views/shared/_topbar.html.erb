<% nav_link = ->(label, path, active) {
     link_to label, path,
       class: "shrink-0 px-3 py-1.5 rounded-md text-sm transition-colors #{active ? 'text-gray-900 font-medium underline underline-offset-4 decoration-2 decoration-pine-500' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-100'}"
   } %>
<% menu_link = ->(label, path, active) {
     link_to label, path,
       class: "block px-2 py-2 rounded-md text-sm #{active ? 'text-gray-900 font-medium bg-pine-50' : 'text-gray-700 hover:bg-gray-100'}"
   } %>
<% sections = [
     [ "Dashboard", root_path, controller_name == "dashboard" ],
     [ "Vendors", vendors_path, controller_name == "vendors" ],
     [ "Systems", systems_path, controller_name == "systems" ]
   ]
   sections << [ "Audit", audit_events_path, controller_name == "audit_events" ] if current_user.compliance? || current_user.admin? %>

<div class="fixed top-3 inset-x-0 z-40" data-controller="menu">
  <div class="container mx-auto px-5">
    <div class="max-w-5xl mx-auto relative">
      <header class="flex items-center justify-between gap-3
                     h-12 pl-2 pr-2 rounded-lg bg-white/90 backdrop-blur shadow-md">
        <div class="flex items-center gap-1 min-w-0">
          <%= link_to root_path, class: "shrink-0 flex items-center justify-center w-7 h-7 mr-0.5", title: "Home" do %>
            <%= brand_mark %>
          <% end %>
          <%# Desktop: inline nav %>
          <nav class="hidden sm:flex items-center gap-1">
            <% sections.each do |label, path, active| %>
              <%= nav_link.(label, path, active) %>
            <% end %>
          </nav>
        </div>

        <nav class="hidden sm:flex items-center gap-1 shrink-0">
          <span class="text-sm text-gray-400"><%= current_user.name %></span>
          <% if current_user.admin? %>
            <%= link_to "Admin", admin_root_path, class: "shrink-0 px-3 py-1.5 rounded-md text-sm text-gray-600 hover:text-gray-900 hover:bg-gray-100" %>
          <% end %>
          <span class="shrink-0 w-px h-5 bg-gray-200 mx-1"></span>
          <%= button_to "Sign out", logout_path, method: :delete,
                class: "shrink-0 px-3 py-1.5 rounded-md text-sm text-gray-500 hover:text-gray-900 hover:bg-gray-100",
                form_class: "inline shrink-0" %>
        </nav>

        <%# Mobile: hamburger %>
        <button type="button" class="sm:hidden shrink-0 flex items-center justify-center w-9 h-9 rounded-md text-gray-600 hover:text-gray-900 hover:bg-gray-100"
                data-action="menu#toggle" data-menu-target="button"
                aria-label="Menu" aria-expanded="false" aria-haspopup="true">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <line x1="4" y1="7" x2="20" y2="7"></line>
            <line x1="4" y1="12" x2="20" y2="12"></line>
            <line x1="4" y1="17" x2="20" y2="17"></line>
          </svg>
        </button>
      </header>

      <%# Mobile: dropdown panel %>
      <div data-menu-target="panel"
           class="sm:hidden hidden absolute top-full right-0 mt-2 w-52 origin-top-right
                  rounded-lg bg-white shadow-lg border border-gray-200 p-1.5">
        <div class="px-2 py-1.5 text-xs text-gray-400 truncate"><%= current_user.name %></div>
        <% sections.each do |label, path, active| %>
          <%= menu_link.(label, path, active) %>
        <% end %>
        <% if current_user.admin? %>
          <%= link_to "Admin", admin_root_path, class: "block px-2 py-2 rounded-md text-sm text-gray-700 hover:bg-gray-100" %>
        <% end %>
        <%= button_to "Sign out", logout_path, method: :delete,
              class: "w-full text-left px-2 py-2 rounded-md text-sm text-gray-700 hover:bg-gray-100 cursor-pointer",
              form_class: "block" %>
      </div>
    </div>
  </div>
</div>
<div class="h-12" aria-hidden="true"></div>
