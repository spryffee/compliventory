<% if notice %>
  <div class="mb-5 flex items-start gap-2 px-4 py-3 rounded-lg bg-pine-50 border border-pine-200 text-pine-800 text-sm">
    <svg class="w-4 h-4 mt-0.5 shrink-0" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.7-9.3a1 1 0 00-1.4-1.4L9 10.6 7.7 9.3a1 1 0 00-1.4 1.4l2 2a1 1 0 001.4 0l4-4z" clip-rule="evenodd"/></svg>
    <span><%= notice %></span>
  </div>
<% end %>
