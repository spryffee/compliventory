  <div class="mb-5 flex items-start gap-2 px-4 py-3 rounded-lg bg-red-50 border border-red-200 text-red-800 text-sm">
    <svg class="w-4 h-4 mt-0.5 shrink-0" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M8.3 2.3a2 2 0 013.4 0l6.5 11A2 2 0 0116.5 16h-13a2 2 0 01-1.7-2.7l6.5-11zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-6a1 1 0 00-1 1v3a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
    <span><%= alert %></span>
  </div>
<% end %>
