# Per-destination deploy values. Copy to the env file for the destination you're
# deploying (gitignored), fill in, then `kamal deploy -d <destination>` with no
# manual exports. config/deploy.<destination>.yml loads its own file via dotenv,
# so names here need no prefix — destinations never load together.
#
#   cp .env.example .env.demo && $EDITOR .env.demo       # demo
#   cp .env.example .env.production && $EDITOR .env.production   # later, if needed

# Public hostname (DNS A record → your server).
DOMAIN=compliventory-demo.example.com

# The server this destination runs on (Kamal web host + Postgres accessory host).
SERVER_IP=203.0.113.10

# Postgres password — the app and the DB accessory both use this. Generate once:
#   openssl rand -hex 24
COMPLIVENTORY_DATABASE_PASSWORD=change-me
