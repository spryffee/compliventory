# Demo deploy values. Copy to `.env` (gitignored) and fill in — then just run
# `kamal deploy -d demo` with no manual exports. config/deploy.demo.yml loads
# this file via dotenv, and .kamal/secrets.demo reads the DB password from it.
#
#   cp .env.example .env && $EDITOR .env

# Public hostname of the demo (DNS A record → your server).
DEMO_DOMAIN=compliventory-demo.example.com

# The server the demo runs on (Kamal web host + Postgres accessory host).
DEMO_SERVER_IP=203.0.113.10

# Postgres password — the app and the DB accessory both use this. Generate once:
#   openssl rand -hex 24
COMPLIVENTORY_DATABASE_PASSWORD=change-me
