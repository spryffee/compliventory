# Secrets for the `demo` destination — Kamal loads this (plus .kamal/secrets-common)
# when you deploy with `-d demo`; the plain .kamal/secrets is only for the default
# (no-destination) deploy. Values here are references only — no raw creds, safe for
# git. COMPLIVENTORY_DATABASE_PASSWORD comes from the gitignored `.env`, which
# config/deploy.demo.yml loads into ENV before these secrets resolve, so nothing
# needs a manual export.
RAILS_MASTER_KEY=$(cat config/master.key)
COMPLIVENTORY_DATABASE_PASSWORD=$COMPLIVENTORY_DATABASE_PASSWORD
POSTGRES_PASSWORD=$COMPLIVENTORY_DATABASE_PASSWORD
